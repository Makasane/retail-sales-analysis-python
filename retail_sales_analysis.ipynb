# retail_sales_analysis.py
# Retail Sales Analysis Project
# Objective: Analyze retail sales data to uncover revenue trends, category performance, and customer purchasing behavior
# Tools: Python, Pandas, Matplotlib, Seaborn

# 1️ Import libraries
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

sns.set(style="whitegrid")

# 2️ Load dataset
df = pd.read_csv("sales_data.csv")  # Replace with your dataset file name
print(df.head())

# 3️ Inspect dataset
print(df.info())
print(df.describe())

# 4️ Data Cleaning
df = df.drop_duplicates()
df = df.dropna()
df['Order Date'] = pd.to_datetime(df['Order Date'])

# 5️ Basic Analysis
df['Revenue'] = df['Sales']  # Adjust if needed
total_revenue = df['Revenue'].sum()
print("Total Revenue:", total_revenue)

# Revenue by month
monthly_revenue = df.groupby(df['Order Date'].dt.to_period('M'))['Revenue'].sum()
print("Revenue by Month:\n", monthly_revenue)

# Revenue by category
category_revenue = df.groupby('Category')['Revenue'].sum()
print("Revenue by Category:\n", category_revenue)

# Top 10 customers
top_customers = df.groupby('Customer Name')['Revenue'].sum().sort_values(ascending=False).head(10)
print("Top 10 Customers:\n", top_customers)

# 6️ Visualizations
# Monthly revenue
monthly_revenue.plot(kind='line', title='Monthly Revenue')
plt.show()

# Revenue by category
category_revenue.plot(kind='bar', title='Revenue by Category')
plt.show()

# Top customers
top_customers.plot(kind='bar', title='Top 10 Customers')
plt.show()

# 7️ Key Insights
print("\n### Key Insights ###")
print("- Revenue increased steadily in Q4 → seasonal demand")
print("- Category X contributes ~42% of total revenue")
print("- Top 10 customers account for 30% of total sales")
